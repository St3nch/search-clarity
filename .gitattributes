# Normalize text files for consistent diffs across Windows/macOS/Linux
* text=auto

# Project text files
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.csv text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.ps1 text eol=crlf

# Binary/document artifacts
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.docx binary
*.xlsx binary
*.pptx binary
*.zip binary
